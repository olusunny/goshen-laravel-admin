{
  "name": "church-tools/digital-counseling-addon",
  "description": "Private digital counseling addon for Laravel and mobile church applications.",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "ChurchTools\\DigitalCounseling\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ChurchTools\\DigitalCounseling\\CounselingServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

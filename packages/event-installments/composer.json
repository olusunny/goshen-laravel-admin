{
    "name": "personal/event-installments",
    "description": "Laravel event booking, installment payment, ticket, QR, PDF, and check-in addon.",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Personal\\EventInstallments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Personal\\EventInstallments\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/foundation": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/mail": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "stripe/stripe-php": "^20.2"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "suggest": {
        "laravel/sanctum": "Recommended for mobile check-in API token authentication.",
        "simplesoftwareio/simple-qrcode": "Recommended for QR code image generation.",
        "barryvdh/laravel-dompdf": "Recommended for PDF ticket generation.",
        "spatie/icalendar-generator": "Recommended for ICS calendar generation."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Personal\\EventInstallments\\EventInstallmentsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
